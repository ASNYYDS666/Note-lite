{
  "dashboard": {
    "id": null,
    "uid": "note-lite-concurrency",
    "title": "Note-lite Concurrency Monitor",
    "tags": [
      "note-lite",
      "concurrency",
      "k6"
    ],
    "timezone": "browser",
    "editable": true,
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "ThreadPool - Active Threads",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "hikaricp_connections_active",
            "legendFormat": "active",
            "refId": "A"
          },
          {
            "expr": "hikaricp_connections_idle",
            "legendFormat": "idle",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 8,
                  "color": "yellow"
                },
                {
                  "value": 10,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "HikariCP - Pending Threads",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "hikaricp_connections_pending",
            "legendFormat": "pending",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 1,
                  "color": "yellow"
                },
                {
                  "value": 10,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "JVM Heap Memory (MB)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Used (MB)",
            "refId": "A"
          },
          {
            "expr": "jvm_memory_max_bytes{area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Max (MB)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "mbytes"
          }
        }
      },
      {
        "id": 4,
        "title": "API Response Time (ms)",
        "type": "timeseries",
        "gridPos": {
          "x": 8,
          "y": 8,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{uri=~\"/api/v1/note/.*\"}[30s]) / rate(http_server_requests_seconds_count{uri=~\"/api/v1/note/.*\"}[30s]) * 1000",
            "legendFormat": "{{uri}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 5,
        "title": "SSE Active Connections",
        "type": "timeseries",
        "gridPos": {
          "x": 16,
          "y": 8,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "sse_connections_active",
            "legendFormat": "active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 20,
                  "color": "yellow"
                },
                {
                  "value": 40,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "GC Pause Time",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum[1m])",
            "legendFormat": "{{action}} {{cause}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 7,
        "title": "HTTP Error Rate (5xx %)",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m])) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 1,
                  "color": "yellow"
                },
                {
                  "value": 5,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Request Rate (req/s)",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 16,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "round(sum(rate(http_server_requests_seconds_count[1m])))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 9,
        "title": "HikariCP Connection Acquire Time Max",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 22,
          "w": 8,
          "h": 4
        },
        "targets": [
          {
            "expr": "hikaricp_connections_acquire_seconds_max",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 10,
        "title": "HikariCP Active + Pending",
        "type": "stat",
        "gridPos": {
          "x": 8,
          "y": 22,
          "w": 8,
          "h": 4
        },
        "targets": [
          {
            "expr": "hikaricp_connections_active",
            "refId": "A"
          },
          {
            "expr": "hikaricp_connections_pending",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "title": "SSE Connection Total / Errors",
        "type": "stat",
        "gridPos": {
          "x": 16,
          "y": 22,
          "w": 8,
          "h": 4
        },
        "targets": [
          {
            "expr": "sse_connections_total",
            "refId": "A"
          },
          {
            "expr": "sse_connections_errors",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 12,
        "title": "chatExecutor Active",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 26, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "threadpool_pool_active{pool=\"chatExecutor\"}",
            "legendFormat": "active",
            "refId": "A"
          },
          {
            "expr": "threadpool_pool_size{pool=\"chatExecutor\"}",
            "legendFormat": "pool_size",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 13,
        "title": "chatExecutor Queue",
        "type": "timeseries",
        "gridPos": { "x": 6, "y": 26, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "threadpool_queue_size{pool=\"chatExecutor\"}",
            "legendFormat": "queue",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 100, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Tomcat Busy Threads",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 26, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "tomcat_threads_busy_threads",
            "legendFormat": "busy",
            "refId": "A"
          },
          {
            "expr": "tomcat_threads_config_max_threads",
            "legendFormat": "max",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 150, "color": "yellow" },
                { "value": 200, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "Chat API Response Time (ms)",
        "type": "timeseries",
        "gridPos": { "x": 18, "y": 26, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{uri=\"/api/v1/chat\"}[30s]) / rate(http_server_requests_seconds_count{uri=\"/api/v1/chat\"}[30s]) * 1000",
            "legendFormat": "avg",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      }
    ]
  },
  "overwrite": true
}